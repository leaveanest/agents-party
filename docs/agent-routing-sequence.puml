@startuml agent-routing
title Agent Routing And Execution Sequence

autonumber
skinparam shadowing false
skinparam defaultFontName Monospace
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Slack User" as slack_user
participant "Slack" as slack
participant "Slack Conversations API" as slack_api

box "Heroku"
  participant "Slack Events Endpoint\nPOST /agents/slack/events" as slack_events_endpoint
  participant "Mention Handler" as mention_handler
  participant "Message Handler" as message_handler
  participant "Routing Resolver" as routing_resolver
  participant "AgentRunner" as agent_runner
  participant "Selected Agent Runtime" as agent_runtime
  participant "Tool Registry" as tool_registry
  participant "ProviderRouter" as provider_router
  database "PostgreSQL\nworkspace/channel/thread settings\nagents" as pg_routes
end box

participant "LLM Provider" as llm_provider
participant "External Tool APIs\nMaps / Media / SORACOM / SaaS" as tool_apis

slack_user -> slack : Post in channel or thread

alt Explicit app mention
  slack -> slack_events_endpoint : app_mention event
  slack_events_endpoint -> mention_handler : Pass event payload
  mention_handler -> mention_handler : Normalize invocation
  mention_handler -> routing_resolver : Resolve route for new or existing thread
else Message event
  slack -> slack_events_endpoint : message event
  slack_events_endpoint -> message_handler : Pass event payload
  message_handler -> routing_resolver : Resolve active thread route
  routing_resolver -> pg_routes : Read thread state and channel policy
  pg_routes --> routing_resolver : active agent/model and auto-reply policy
  alt Thread inactive or auto-reply disabled
    routing_resolver --> message_handler : No route
    message_handler --> slack : No response
  end
end

routing_resolver -> pg_routes : Resolve agent and model
note right
Precedence:
1. thread
2. channel
3. workspace
4. explicit app fallback
end note
pg_routes --> routing_resolver : effective agent, model, scope
routing_resolver -> slack_api : Fetch thread history when needed
slack_api --> routing_resolver : Thread transcript and attachment context
routing_resolver -> agent_runner : Run resolved agent with resolved model

agent_runner -> agent_runtime : Execute resolved agent
agent_runtime -> tool_registry : Attach allowed tools
agent_runtime -> provider_router : Generate with resolved model and tools
provider_router -> llm_provider : Invoke provider adapter
llm_provider --> provider_router : Text or tool calls

alt Tool calls requested
  provider_router --> agent_runtime : Tool calls
  agent_runtime -> tool_registry : Execute typed tools
  tool_registry -> tool_apis : Read or confirmed write
  tool_apis --> tool_registry : Structured tool output
  tool_registry --> agent_runtime : Tool results
  agent_runtime -> provider_router : Generate final answer with tool results
  provider_router -> llm_provider : Invoke provider adapter
  llm_provider --> provider_router : Final result
end

provider_router --> agent_runtime : Normalized result

agent_runtime --> agent_runner : Slack-ready result
agent_runner --> routing_resolver : Text or generated media

alt Text response
  routing_resolver -> pg_routes : Persist active thread route
  routing_resolver -> slack : Post reply in thread
else Media response
  routing_resolver -> slack : Upload file or post provider handoff
  routing_resolver -> pg_routes : Persist active thread route
end
slack --> slack_user : Show assistant result

note right of routing_resolver
Top-level routing is configuration-driven.
The user message does not select the primary agent by keyword.
end note

note over agent_runner, provider_router
ProviderRouter enforces model registry and capability checks.
It does not infer providers from model name strings.
end note

note over message_handler
Follow-up auto-replies run only when:
- the message is user-authored text
- the thread has an active route in PostgreSQL
- channel auto-reply remains enabled
end note

@enduml
