@startuml agent-routing
title Agent Routing And Execution Sequence

autonumber
skinparam shadowing false
skinparam defaultFontName Monospace
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Slack User" as slack_user
participant "Slack" as slack
participant "Slack Conversations API" as slack_api

box "Google Cloud Project"
  participant "Slack Events Endpoint\nPOST /slack/events" as slack_events_endpoint
  participant "Mention Handler" as mention_handler
  participant "Message Handler" as message_handler
  participant "Agent Routing" as agent_routing
  participant "Agent Router" as agent_router
  participant "Text Specialist(s)" as text_specialists
  participant "Media Specialist" as media_specialist
  database "Firestore\nworkspace/channel settings\nthreads/{thread_ts}" as fs_threads
  participant "Vertex AI" as vertex_ai
  participant "Google Maps Platform" as google_maps
end box

slack_user -> slack : Post in channel or thread

alt Explicit app mention
  slack -> slack_events_endpoint : app_mention event
  slack_events_endpoint -> mention_handler : Pass event payload
  mention_handler -> mention_handler : Normalize invocation
  alt Mention has no prompt text
    mention_handler -> slack : Post thread menu / usage help
    slack --> slack_user : Show menu blocks
  else Mention has prompt text
    mention_handler -> agent_routing : Route request
  end
else Message event
  slack -> slack_events_endpoint : message event
  slack_events_endpoint -> message_handler : Pass event payload
  alt Message starts with bot mention
    message_handler -> mention_handler : Reuse mention flow
  else Plain follow-up message
    message_handler -> fs_threads : Read stored thread state
    fs_threads --> message_handler : active agent_id and status
    message_handler -> fs_threads : Read auto-reply / channel enablement
    alt Active assistant thread and auto-reply enabled
      message_handler -> agent_routing : Continue routed conversation
    else Ignore message
      message_handler --> slack : No response
    end
  end
end

agent_routing -> fs_threads : Check channel enablement
agent_routing -> slack_api : Fetch full thread history
slack_api --> agent_routing : Root message + thread transcript
agent_routing -> agent_router : Build Slack invocation with full context
agent_router -> vertex_ai : Decide direct reply or delegation

alt Direct reply
  vertex_ai --> agent_router : Slack-ready response
  agent_router --> agent_routing : Final text
else One or more text specialists
  loop zero or more text specialists
    agent_router -> text_specialists : Delegate specialist call
    text_specialists -> vertex_ai : Specialist reasoning
    opt Maps specialist
      text_specialists -> google_maps : Places / Routes lookup
      google_maps --> text_specialists : Structured maps data
    end
    vertex_ai --> text_specialists : Specialist result
    text_specialists --> agent_router : Normalized outcome
  end
  agent_router -> vertex_ai : Synthesize final answer
  vertex_ai --> agent_router : Slack-ready response
  agent_router --> agent_routing : Final text
else Media specialist
  agent_router -> media_specialist : Delegate image or video request
  media_specialist -> vertex_ai : Generate media payload
  vertex_ai --> media_specialist : Binary image or video
  media_specialist --> agent_router : Media outcome
  agent_router --> agent_routing : Uploadable media + optional comment
end

alt Text response
  agent_routing -> fs_threads : Persist active agent_id=`assistant`
  agent_routing -> slack : Post reply in thread
else Media response
  agent_routing -> slack : Upload generated file to thread
  agent_routing -> fs_threads : Persist active agent_id=`assistant`
end
slack --> slack_user : Show assistant result

note right of agent_router
The router may combine multiple text specialists in one run.
At most one media specialist can run, and it must be last.
end note

note over agent_routing, slack_api
Before execution, the routing layer always loads the full Slack thread.
Recent thread images may also be downloaded and passed through for image generation.
end note

note over message_handler
Follow-up auto-replies run only when:
- the message is user-authored text
- the thread is marked active in Firestore
- channel auto-reply remains enabled
end note

@enduml
