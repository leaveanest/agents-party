@startuml
title agents-party System Architecture

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName Monospace

actor "Slack User" as slack_user
actor "Browser" as browser
cloud "Slack" as slack
cloud "Google Identity" as google_identity
cloud "Google Maps Platform" as google_maps_platform
cloud "Cloud Translation API" as cloud_translation

package "Google Cloud Project" {
  rectangle "Cloud Run Service" as cloud_run {
    package "agents-party Application" {
      component "FastAPI App" as fastapi_app
      component "Slack Bolt Gateway\nPOST /slack/events" as slack_gateway
      component "Google OAuth Router\nGET /oauth/google/start\nGET /oauth/google/callback" as google_oauth_router
      component "Slack Event Handlers\napp_home_opened / app_mention /\nmessage / reaction_added" as slack_handlers
      component "Agent Routing" as agent_routing
      component "Agent Router" as agent_router
      component "Work Manager" as work_manager
      component "Web Research" as web_research
      component "Google Maps" as google_maps
      component "Translation" as translation
      component "Image Generation" as image_generation
      component "Video Generation" as video_generation
      component "Google OAuth Coordinator" as google_oauth
    }
  }

  rectangle "Secret Manager" as secret_manager
  rectangle "Vertex AI" as vertex_ai

  database "Cloud SQL for PostgreSQL" as postgres {
    folder "agents" as pg_agents
    folder "workspace_app_settings" as pg_workspace_settings
    folder "channel_app_settings" as pg_channel_settings
    folder "slack_threads" as pg_threads
    folder "slack_installations / slack_bots" as pg_slack_installations
    folder "work_items / participants /\nevents / attention_index" as pg_work_items
    folder "google_auth_connections" as pg_google_connections
    folder "google_oauth_states" as pg_google_oauth_states
  }
}

slack_user --> slack : use app
slack --> cloud_run : HTTPS events and interactions
cloud_run --> fastapi_app
fastapi_app --> slack_gateway : /slack/events
fastapi_app --> google_oauth_router : /oauth/google/*

secret_manager --> cloud_run : runtime secrets and config

slack_gateway --> slack_handlers
slack_handlers --> agent_routing : mentions and active-thread replies
slack_handlers --> cloud_translation : flag reaction translation

agent_routing --> pg_workspace_settings : channel enablement defaults
agent_routing --> pg_channel_settings : thread auto-reply overrides
agent_routing --> pg_threads : active assistant thread state
agent_routing --> pg_agents : configured agents
agent_routing --> slack : fetch thread history / post replies / upload files

agent_routing --> agent_router : Slack invocation with full context
agent_router --> vertex_ai : decide direct reply or delegation

agent_router --> work_manager
agent_router --> web_research
agent_router --> google_maps
agent_router --> translation
agent_router --> image_generation
agent_router --> video_generation

work_manager --> vertex_ai : structured task execution
work_manager --> pg_work_items : relational task persistence

web_research --> vertex_ai : web tool orchestration
google_maps --> vertex_ai : maps reasoning
google_maps --> google_maps_platform : Places / Routes API calls
translation --> vertex_ai : request-driven translation
image_generation --> vertex_ai : Gemini image generation
video_generation --> vertex_ai : Gemini prompt planning and Veo rendering

browser --> google_oauth_router : open signed OAuth start URL
google_oauth_router --> google_oauth
google_oauth --> pg_google_oauth_states : create / consume state
google_oauth --> pg_google_connections : encrypted token storage
google_oauth --> google_identity : authorization and token exchange
google_identity --> browser : consent and redirect
browser --> google_oauth_router : callback redirect

note bottom of postgres
Stored data:
- workspace and channel app settings
- active assistant thread state
- Slack installation store records
- work items, participants, events, and attention index
- Google OAuth connection documents
- short-lived Google OAuth state documents
end note

note top of cloud_run
Cloud Run hosts one FastAPI service for Slack events,
health checks, and Google OAuth browser callbacks.
Schema migrations run separately via a Cloud Run Job.
end note

note right of postgres
Production relational storage runs on Cloud SQL for PostgreSQL
and is deployed through terraform/environments/dev/.
end note

@enduml
