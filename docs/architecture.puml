@startuml
title agents-party System Architecture

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName Monospace

actor "Slack User" as slack_user
cloud "Slack" as slack

package "Google Cloud Project" {
  rectangle "Cloud Run Service" as cloud_run {
    package "agents-party Application" {
      component "Slack Events Endpoint\nPOST /slack/events" as slack_events_endpoint
      component "App Home / Mention Handling" as slack_handlers
      component "Agent Routing" as agent_routing
      component "Agent Selector" as agent_selector
      component "Work Manager" as work_manager
    }
  }

  rectangle "Secret Manager" as secret_manager
  rectangle "Vertex AI" as vertex_ai

  database "Firestore" as firestore {
    folder "agents/{agent_id}" as fs_agents

    folder "workspaces/{team_id}" as fs_workspace {
      folder "app_settings/default" as fs_workspace_settings

      folder "channels/{channel_id}" as fs_channel {
        folder "app_settings/default" as fs_channel_settings
        folder "threads/{thread_ts}" as fs_threads
      }

      folder "work_items/{work_item_id}" as fs_work_item {
        folder "participants/{user_id}" as fs_participants
        folder "events/{event_id}" as fs_events
      }

      folder "attention_index/{user_id}/work_items/{work_item_id}" as fs_attention
    }
  }
}

slack_user --> slack : use app
slack --> cloud_run : HTTPS request
cloud_run --> slack_events_endpoint : /slack/events

secret_manager --> cloud_run : Slack credentials\nruntime secret injection

slack_events_endpoint --> slack_handlers
slack_handlers --> agent_routing

agent_routing --> fs_workspace_settings : workspace default agent
agent_routing --> fs_channel_settings : channel default agent
agent_routing --> fs_threads : thread-level route
agent_routing --> fs_agents : load enabled agents

agent_routing --> agent_selector : fallback selection
agent_selector --> vertex_ai : selection request

agent_routing ..[#gray,dashed]> work_manager : selected agent execution\n(not wired yet)

work_manager --> vertex_ai : task execution
work_manager --> fs_work_item : create / read / update
work_manager --> fs_participants : assignees / roles / attention
work_manager --> fs_events : work item history
work_manager --> fs_attention : per-user attention index

note bottom of firestore
Slack routing data:
- workspace app settings
- channel app settings
- thread route overrides
- global agent definitions

Work management data:
- work items
- participants
- events
- attention index
end note

note top of cloud_run
Deployment runtime for the HTTP service.
end note

@enduml
