# Copy this file to .env for Docker Compose, or export the values in your shell
# before running `vp run ...` commands locally.

APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# Local PostgreSQL from `docker compose up -d postgres`.
DATABASE_URL=postgresql://agents_party:agents_party@localhost:5432/agents_party

# Local single-workspace Slack development.
# Use Slack OAuth settings instead when testing the installation store.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Optional Slack OAuth installation store testing.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_STATE_SECRET=

# Optional local model/provider fallback.
AGENT_MODEL=google:gemini-2.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional local worker queue testing.
REDIS_URL=redis://localhost:6379
SLACK_AGENT_QUEUE_ENABLED=false
