# Copy this file to .env for Docker Compose, or export the values in your shell
# before running `vp run ...` commands locally.

APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# Local PostgreSQL from `docker compose up -d postgres`.
DATABASE_URL=postgresql://agents_party:agents_party@localhost:5432/agents_party

# Slack OAuth installation store.
# Leave these blank for health-check-only local Docker Compose startup.
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_STATE_SECRET=

# Optional local model selection.
AGENT_MODEL=google:gemini-2.5-flash
IMAGE_GENERATION_MODEL=google:gemini-2.5-flash-image
VIDEO_GENERATION_MODEL=google:veo-3.1-fast-generate-001

# Optional local worker queue testing.
REDIS_URL=redis://localhost:6379
SLACK_AGENT_QUEUE_ENABLED=false

# Optional S3-compatible object storage.
# AWS/ECS should prefer task-role credentials. Heroku Bucketeer can provide BUCKETEER_* vars.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_PREFIX=
OBJECT_STORAGE_PUBLIC_BASE_URL=
